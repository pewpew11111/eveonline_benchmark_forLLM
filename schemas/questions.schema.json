{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EVE Online Benchmark Questions",
  "type": "object",
  "required": ["benchmark_version", "language", "scope", "items"],
  "properties": {
    "benchmark_version": { "type": "string" },
    "language": { "const": "ko" },
    "scope": { "const": "single_turn_text" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "question",
          "main_case",
          "sub_element",
          "difficulty",
          "ambiguity_level",
          "requires_current_patch",
          "rubric_profile",
          "source_pack",
          "gold_answer",
          "acceptable_variants",
          "known_traps"
        ],
        "properties": {
          "question_id": { "type": "string", "pattern": "^[A-Z]+-[A-Z]+-[A-Z0-9]+$" },
          "question": { "type": "string", "minLength": 1 },
          "main_case": {
            "enum": ["INFO", "PLAN", "COMPARE", "ANALYZE", "DECIDE", "HOWTO", "FIX"]
          },
          "sub_element": {
            "enum": ["COMBAT", "SHIP", "INDUSTRY", "MARKET", "SKILL", "MINING", "EXPLORE", "LORE", "MECH", "CORP"]
          },
          "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
          "ambiguity_level": { "enum": ["low", "medium", "high"] },
          "requires_current_patch": { "type": "boolean" },
          "rubric_profile": { "type": "string", "minLength": 1 },
          "source_pack": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["label", "url", "priority"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "format": "uri" },
                "priority": { "type": "integer", "minimum": 1, "maximum": 5 }
              },
              "additionalProperties": false
            }
          },
          "gold_answer": {
            "type": "object",
            "required": ["must_include", "must_not_include", "ideal_answer_summary"],
            "properties": {
              "must_include": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "must_not_include": { "type": "array", "items": { "type": "string" } },
              "ideal_answer_summary": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "acceptable_variants": { "type": "array", "items": { "type": "string" } },
          "known_traps": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
